{
  "name": "reactbuilder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "author": "tejas",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:react dev:electron",
    "dev:electron": "npm run transpile:electron && cross-env NODE_ENV=development electron .",
    "dev:react": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "copy:splash": "node -e \"require('fs').copyFileSync('src/electron/splash.html', 'dist-electron/splash.html')\"",
    "transpile:electron": "tsc --project src/electron/tsconfig.json && npm run copy:splash",
    "dist:mac": "npm run transpile:electron && npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run transpile:electron && npm run build && electron-builder --win --x64",
    "dist:linux": "npm run transpile:electron && npm run build && electron-builder --linux --x64"
  },
  "dependencies": {
    "@iconify-json/material-symbols": "^1.2.61",
    "@iconify-json/mdi": "^1.2.3",
    "@tailwindcss/vite": "^4.1.13",
    "os-utils": "^0.0.14",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@iconify/react": "^6.0.2",
    "@types/os-utils": "^0.0.4",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "cross-env": "^10.0.0",
    "electron": "^38.1.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "npm:rolldown-vite@7.1.12"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.1.12"
  }
}
